{
  "name": "8989",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "tsx server/src/app.ts",
    "start:clock": "cross-env GAME_CLOCK_ENABLED=1 tsx server/src/app.ts",
    "server:dev": "tsx watch server/src/app.ts",
    "build": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "eval:planning:offline": "tsx server/src/evals/runOfflinePlanningEval.ts --dataset server/evals/planning_offline_eval_v1.json",
    "rag:index:replays": "tsx scripts/index_replays.ts",
    "test:planner:prompt": "tsx server/tests/planner_prompt.test.ts",
    "eval:orchestrator:stress": "tsx server/src/evals/runOrchestratorStress.ts",
    "gate:scale:3000:mock": "tsx server/src/evals/runOrchestratorStress.ts --player-agents 1500 --enemy-agents 1500 --concurrency 32 --batch-size 32 --mode mock --output tmp/gates/scale_3000_mock.json --min-success-rate 0.99 --max-p95-ms 200000 --max-fallback-rate 0.02 --max-failure-count 10",
    "gate:scale:3000:gateway": "tsx server/src/evals/runOrchestratorStress.ts --player-agents 1500 --enemy-agents 1500 --concurrency 16 --batch-size 16 --mode gateway --output tmp/gates/scale_3000_gateway.json --min-success-rate 0.95 --max-p95-ms 25000 --max-fallback-rate 0.10 --max-failure-count 150",
    "gate:gateway:preflight": "py -3.11 scripts/run_gateway_preflight_gate.py",
    "gate:scale:3000:gateway:ready": "npm run gate:gateway:preflight && npm run gate:scale:3000:gateway",
    "sim": "tsx server/src/evals/runDualPlayerSimulation.ts --mode mock --ticks 20 --output tmp/sim_latest.json",
    "sim:quick": "tsx server/src/evals/runDualPlayerSimulation.ts --mode mock --ticks 10 --output tmp/sim_quick.json",
    "sim:full": "tsx server/src/evals/runDualPlayerSimulation.ts --mode mock --ticks 60 --output tmp/sim_full.json",
    "sim:gateway": "tsx server/src/evals/runDualPlayerSimulation.ts --mode gateway --ticks 20 --output tmp/sim_gateway_latest.json",
    "sim:gateway:fast": "tsx server/src/evals/runDualPlayerSimulation.ts --mode gateway --ticks 12 --output tmp/sim_gateway_fast.json --verbose",
    "sim:13factions": "tsx server/src/evals/runMultiFactionSimulation.ts --mode mock --ticks 20 --output tmp/sim_13f_latest.json",
    "sim:13factions:gateway": "tsx server/src/evals/runMultiFactionSimulation.ts --mode gateway --ticks 20 --output tmp/sim_13f_gateway.json --verbose",
    "sim:13factions:gateway:50": "tsx server/src/evals/runMultiFactionSimulation.ts --mode gateway --ticks 50 --output tmp/sim_13f_gateway_50tick.json --verbose",
    "sim:verbose": "tsx server/src/evals/runDualPlayerSimulation.ts --mode mock --ticks 20 --verbose --output tmp/sim_verbose.json",
    "gate:phase5:hardening": "tsx server/src/evals/runPhase5HardeningGate.ts",
    "gate:ai:mainline:stability": "tsx server/src/evals/runAiMainlineStabilityGate.ts",
    "gate:save-slots:restore-apply:stability": "tsx server/src/evals/runSaveSlotsRestoreApplyGate.ts",
    "gate:session:security": "tsx server/src/evals/runSessionSecurityGate.ts",
    "gate:ai:trio": "npm run gate:session:security && npm run gate:ai:mainline:stability && set NIGHTLY_REUSE_LATEST_GATES=1&& set NIGHTLY_REUSE_MAX_REPORT_AGE_SEC=900&& tsx server/src/evals/runAiNightlyAcceptanceGate.ts && tsx server/src/evals/runGateTrioSummary.ts",
    "gate:ai:nightly:acceptance": "tsx server/src/evals/runAiNightlyAcceptanceGate.ts",
    "gate:ai:trio:summary": "tsx server/src/evals/runGateTrioSummary.ts",
    "gate:godot:week1": "py -3.11 godot-client/tools/run_week1_gate.py --no-allow-stale-runtime-schema",
    "gate:godot:week1:compat": "npm run gate:godot:week1:compat:debug-only",
    "gate:godot:week1:compat:debug-only": "py -3.11 godot-client/tools/run_week1_gate.py",
    "godot:ops:cli": "py -3.11 godot-client/tools/slg_ops_cli.py",
    "godot:ops:visual-validate": "py -3.11 godot-client/tools/validate_visual_mapping.py",
    "gate:harness:isolation": "py -3.11 scripts/run_harness_isolation_gate.py",
    "test:ai:quota": "tsx server/tests/ai_quota.test.ts",
    "test:world:mutation-lock": "tsx server/tests/world_mutation_lock.test.ts",
    "test:session:manager": "tsx server/tests/session_manager.test.ts",
    "security:auth:validate": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/security/validate_git_auth_posture.ps1 -RepoPath .",
    "security:auth:harden": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/security/harden_repo_git_auth.ps1 -RepoPath .",
    "security:branch:protect": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/security/configure_branch_protection.ps1 -RepoPath ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "p-limit": "^7.3.0",
    "ws": "^8.18.0",
    "xstate": "^5.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/ws": "^8.18.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "mem0ai": "^2.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
