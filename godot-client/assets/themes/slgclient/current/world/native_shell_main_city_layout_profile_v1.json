  "profile_id": "native_shell_main_city_layout_profile_v1",
  "schema_version": 1,
  "purpose": "Main city visual layout profile for native_slg_shell center stage. 5x5 is the visual shell; only the inner 3x3 is the active building grid.",
  "readable_name": "主城 5x5 视觉壳 / 3x3 功能核心",
  "coordinate_system": {
    "origin": "top-left visual grid cell",
    "x_range": [0, 4],
    "y_range": [0, 4],
    "center_slot": [2, 2],
    "tile_footprint_px": [240, 240],
    "asset_canvas_px": [384, 384],
    "asset_anchor": "bottom-center footprint center"
  },
  "city_grid_projection": {
    "type": "isometric_2_to_1",
    "tile_width": 60,
    "tile_height": 30,
    "origin": [150, 36],
    "elevation_scale": 1,
    "anchor_rule": "center",
    "z_sort_rule": {
      "type": "grid_sum_then_x",
      "base_z_index": 10,
      "sort_step": 10,
      "x_step": 1,
      "flat_layers": ["foundation", "continuous_city_wall_ring"],
      "layer_offsets": {
        "foundation": -10,
        "continuous_city_wall_ring": -8,
        "breathing": 0,
        "reserved_plot": 10,
        "city_gate": 18,
        "corner_tower": 18,
        "active_building": 20
      }
    }
  },
  "grid": {
    "visual_grid": {
      "columns": 5,
      "rows": 5,
      "cell_size": [42, 24],
      "preview_size": [300, 180],
      "meaning": "Visual shell used for composition, wall ring, gates, reserved plots, and breathing room."
    },
    "active_grid": {
      "columns": 3,
      "rows": 3,
      "origin_slot": [1, 1],
      "meaning": "The only first-phase clickable and upgradeable city-building slots."
    }
  },
  "debug_labels": {
    "enabled_by_default": false,
    "rule": "Chinese names are for tooling and debug overlays only. Runtime UI should read copy from native shell copy/profile sources."
  },
