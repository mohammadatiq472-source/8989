HOST=127.0.0.1
PORT=8787

LLM_RELAY_URL=http://216.40.86.55:3100/
LLM_RELAY_PROTOCOL=openai_compat
LLM_RELAY_API_KEY=
LLM_RELAY_API_KEYS=
LLM_RELAY_API_KEYS_FILE=
LLM_RELAY_MODEL=openrouter/healer-alpha
# Optional: when set, planner gateway prefers local AI-server proxy endpoint.
AI_SERVER_URL=

LOCAL_MODEL_ENDPOINT=http://127.0.0.1:8080/v1
LOCAL_MODEL_NAME=qwen3.5-2b-q4_k_m

PLANNER_MAX_TOKENS=
# 默认留空：不限制单次输出 token，保持规划能力上限
PLANNER_PRICE_PER_MILLION_USD=0
PLANNER_REQUEST_TIMEOUT_MS=45000
PLANNER_REQUEST_MAX_ATTEMPTS=3
PLANNER_REQUEST_RETRY_BASE_MS=600
PLANNER_REQUEST_RETRY_MAX_MS=4000
PLANNER_REQUEST_MAX_ELAPSED_MS=65000

TRACE_ENABLED=1

# Multiplayer session boundaries
SESSION_HEARTBEAT_TIMEOUT_MS=30000
SESSION_STALE_TTL_MS=600000
SESSION_MAX_ACTIVE=1024
SESSION_MAX_PLAYER_NAME_LENGTH=32
# Gateway preflight key requirement: 0=allow anonymous/free model mode (warn), 1=require key
GATEWAY_PREFLIGHT_REQUIRE_KEY=0

# Main HTTP server guardrails
HTTP_REQUEST_TIMEOUT_MS=60000
HTTP_HEADERS_TIMEOUT_MS=65000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
HTTP_MAX_REQUESTS_PER_SOCKET=100

# AI-Server queue and timeout guardrails
AI_SERVER_PORT=8788
AI_SERVER_CONCURRENCY=8
AI_SERVER_MAX_QUEUE=64
AI_SERVER_QUEUE_WAIT_TIMEOUT_MS=20000
AI_SERVER_UPSTREAM_TIMEOUT_MS=30000
AI_SERVER_REQUEST_TIMEOUT_MS=52000
AI_SERVER_HEADERS_TIMEOUT_MS=57000
AI_SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
AI_SERVER_MAX_REQUESTS_PER_SOCKET=200
AI_SERVER_MAX_BODY_BYTES=1048576

MEM0_API_KEY=
MEM0_BASE_URL=
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_API_VERSION=


REPLAY_RAG_PROVIDER=hash
REPLAY_RAG_TOP_K=3
REPLAY_RAG_MAX_EXCERPT_CHARS=220
REPLAY_RAG_EMBEDDING_DIMENSION=192
REPLAY_RAG_EMBEDDING_TIMEOUT_MS=6000
REPLAY_RAG_FAIL_OPEN=true
REPLAY_RAG_EMBEDDING_URL=
REPLAY_RAG_EMBEDDING_MODEL=text-embedding-3-small
REPLAY_RAG_EMBEDDING_API_KEY=
REPLAY_RAG_EMBEDDING_API_KEYS=
REPLAY_RAG_EMBEDDING_API_KEYS_FILE=

REPLAY_RAG_CACHE=true
REPLAY_RAG_CACHE_FILE=tmp/replay_rag_index_cache.json
